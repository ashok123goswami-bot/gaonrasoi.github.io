<script>
  // reveal cards on scroll
  const cards = document.querySelectorAll('.card');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach((e,i)=>{
      if(e.isIntersecting){
        setTimeout(()=> e.target.classList.add('revealed'), i%4*70);
        io.unobserve(e.target);
      }
    });
  }, {threshold:0.15});
  cards.forEach(c=>io.observe(c));

  // mobile menu (simple toggle -> reuses nav links inline)
  const menuBtn = document.getElementById('menuBtn');
  let mobileNav = null;
  menuBtn?.addEventListener('click', ()=>{
    if(mobileNav){ mobileNav.remove(); mobileNav=null; return; }
    mobileNav = document.createElement('div');
    mobileNav.style.cssText = 'position:absolute;top:100%;left:0;right:0;background:#0a0906;border-bottom:1px solid rgba(212,175,55,0.28);padding:18px 28px;display:flex;flex-direction:column;gap:16px;font-weight:600;';
    mobileNav.innerHTML = `
      <a href="#products">Products</a>
      <a href="#story">Our Story</a>
      <a href="#quality">Why Us</a>
      <a href="#contact">Contact</a>`;
    document.querySelector('header').appendChild(mobileNav);
    mobileNav.querySelectorAll('a').forEach(a=>a.addEventListener('click', ()=>{ mobileNav.remove(); mobileNav=null; }));
  });
</script>

